#!/usr/bin/env ruby
# mode: ruby-mode

# frozen_string_literal: true

require_relative "../lib/fat_term"

ctx = FatTerm::Backends::Curses::Context.new

begin
  ctx.start

  screen = FatTerm::Screen.new(rows: ::Curses.lines, cols: ::Curses.cols)
  ctx.apply_layout(screen)

  renderer = FatTerm::Backends::Curses::Renderer.new(context: ctx, screen: screen)

  env = FatTerm::Env.detect
  key_decoder = FatTerm::Backends::Curses::KeyDecoder.new(env: env)
  event_source = FatTerm::Backends::Curses::EventSource.new(context: ctx, key_decoder: key_decoder)

  terminal = FatTerm::Terminal.new(screen: screen, renderer: renderer, event_source: event_source)

  # Pinned overlay session for alerts.
  terminal.pin(FatTerm::Sessions::AlertSession.new)

  # Focused interactive session.
  terminal.push(FatTerm::Sessions::ShellSession.new(prompt: -> { Dir.pwd + '> '}))

  terminal.go
ensure
  ctx.close
end
