#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/fat_term"
require "open3"

prompt = FatTerm::Prompt.new { "#{Dir.pwd}> " }

FatTerm::Terminal.new(
  prompt: prompt,
  on_accept: ->(line, terminal:, session:) do
    out, _ = Open3.capture2e(line)
    session.append_output(out)
    [[:send, :alert, :clear, {}]]
  rescue Errno::ENOENT
    [[:send, :alert, :show, { level: :error, message: "Command not found (#{line})" }]]
  end
).go
