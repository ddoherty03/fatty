#!/usr/bin/env ruby
# frozen_string_literal: true

# mode: ruby

#!/usr/bin/env ruby
# frozen_string_literal: true

require "yaml"
require "optparse"
require "pathname"
require "debug"

begin
  require_relative "../lib/fat_term"
rescue LoadError
  require "fat_term"
end

options = {}

parser = OptionParser.new do |opts|
  opts.banner = "Usage: fat_term [options]"

  opts.on("--env", "Print detected terminal environment and exit") do
    options[:env] = true
  end

  opts.on("--config", "Print detected environment and key configuration") do
    options[:config] = true
  end

  opts.on("-h", "--help", "Show this help") do
    puts opts
    exit 0
  end
end

parser.parse!(ARGV)

# ------------------------------------------------------------
# Helpers
# ------------------------------------------------------------

def keydefs_path
  Pathname.new(ENV["XDG_CONFIG_HOME"] || File.join(Dir.home, ".config"))
          .join("fat_term", "keydefs.yaml")
end

# ------------------------------------------------------------
# --env
# ------------------------------------------------------------

if options[:env]
  env = FatTerm::Env.detect
  puts env.to_yaml
  exit 0
end

# ------------------------------------------------------------
# --config
# ------------------------------------------------------------

if options[:config]
  env = FatTerm::Env.detect
  terminal = env[:terminal]

  binding.break
  result = FatTerm.config
  puts result.to_yaml
  exit 0
end

# ------------------------------------------------------------
# Default / future behavior
# ------------------------------------------------------------

warn "fat_term: no command specified (try --env or --config)"
exit 1



